# marketing-os — 환경 변수 템플릿
#
# 사용법:
#   1) cp .env.example .env
#   2) 아래에서 **실제로 쓰는 도구만** 채우세요 (전부 필수 아닙니다)
#   3) 각 항목의 설치 안내: mcp-setup/{도구}/ 참조
#
# ⚠️ .env 는 git에 커밋되지 않습니다 (.gitignore 등록됨)
# 💡 "마케팅팀 구축하자" 를 실행하면 우리 회사에 필요한 도구만 골라 안내합니다.

# ════════════════════════════════════════════════
# 데이터 분석
# ════════════════════════════════════════════════

# GA4 · 웹사이트 트래픽 분석  → mcp-setup/ga4/
# 인증은 ADC 방식: gcloud auth application-default login
GA4_PROPERTY_ID=                    # GA4 속성 ID (숫자 9자리)

# Google Sheets · OAuth 기반이라 .env 키 없음 → mcp-setup/google-sheets/
# 자격증명: mcp-server/oauth_credentials.json (Google Cloud Console > Desktop App)

# ════════════════════════════════════════════════
# 리서치 · 트렌드
# ════════════════════════════════════════════════

# Firecrawl · 경쟁사·시장 웹 스크랩  → mcp-setup/firecrawl/
# 발급: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=                  # fc-xxx 형식

# YouTube Data API · 채널·키워드 분석  → mcp-setup/youtube-data/
# 발급: console.cloud.google.com > APIs & Services > Credentials
YOUTUBE_API_KEY=

# (선택) YouTube Analytics · 내 채널 소유자 데이터(구독 변동·이탈)
# OAuth 클라이언트: console.cloud.google.com > Credentials > OAuth Client (Desktop)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# 네이버 데이터랩 · 검색어 트렌드·쇼핑인사이트  → mcp-setup/naver/
# 발급: developers.naver.com → 애플리케이션 등록 → 「데이터랩(검색어트렌드)」+「데이터랩(쇼핑인사이트)」 체크
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ════════════════════════════════════════════════
# 광고 성과
# ════════════════════════════════════════════════

# 네이버 검색광고(SearchAd) · 광고비·ROAS  → mcp-setup/naver/
# 발급: manage.searchad.naver.com → 도구 → API 사용 관리
NAVER_SEARCHAD_API_KEY=             # 액세스 라이선스
NAVER_SEARCHAD_SECRET_KEY=          # AQAA...== 형태
NAVER_SEARCHAD_CUSTOMER_ID=         # 계정 번호(숫자)

# Google Ads · 검색·디스플레이 성과  → mcp-setup/ads/
# 발급: ads.google.com/aw/apicenter (Manager 계정 · 1~2일 승인 대기)
# 인증은 ADC: gcloud auth application-default login
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta Ads · 공식 hosted MCP(OAuth)로 전환됨 → .env 키 불필요
# claude mcp add --transport http --scope user meta-ads https://mcp.facebook.com/ads

# ════════════════════════════════════════════════
# 콘텐츠 발행
# ════════════════════════════════════════════════

# Buffer · SNS 멀티 채널 예약 발행  → mcp-setup/buffer/
# 발급: https://publish.buffer.com/account/apps
BUFFER_ACCESS_TOKEN=

# Gmail · 뉴스레터 발송
# 앱 비밀번호: myaccount.google.com/apppasswords (2단계 인증 필요)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ════════════════════════════════════════════════
# 영상 · 음성 (선택)
# ════════════════════════════════════════════════

# HeyGen · 아바타 영상  → 발급: https://app.heygen.com/settings
HEYGEN_API_KEY=

# ElevenLabs · 한국어 TTS·음성 클론  → mcp-setup/영상제작/
ELEVENLABS_API_KEY=

# ════════════════════════════════════════════════
# 알림 · 승인 (선택)
# ════════════════════════════════════════════════

# Discord Webhook · 산출물 발송·승인 게이트  → mcp-setup/discord/
# 발급: 채널 우클릭 > 채널 편집 > 연동 > 웹훅 > 새 웹훅 > URL 복사
DISCORD_WEBHOOK_URL=                # 기본 채널
DISCORD_WEBHOOK_URL_ALERTS=         # 알림(임계값 위반)
DISCORD_WEBHOOK_URL_APPROVALS=      # 승인 요청

# ════════════════════════════════════════════════
# 광고 임계값 — 알림이 울리는 기준선 (회사에 맞게 조정)
# ════════════════════════════════════════════════
# WARN = 경고 알림 · BLOCK = 즉시 조치 필요

THRESHOLD_ROAS_WARN=2.0
THRESHOLD_ROAS_BLOCK=1.0
THRESHOLD_CPA_WARN=30000
THRESHOLD_CPA_BLOCK=50000
THRESHOLD_CTR_WARN=1.0
THRESHOLD_CTR_BLOCK=0.5
THRESHOLD_DAILY_BUDGET_WARN=100000
THRESHOLD_DAILY_BUDGET_BLOCK=200000
