# marketing-os — 환경 변수 템플릿
#
# 사용법:
#   1) cp .env.example .env
#   2) Claude Code 에서 "MCP 전체 설치하자" 호출 (또는 개별 클립별)
#   3) Claude 안내에 따라 각 키 발급 후 .env 에 자동 등록됨
#
# 발급 우선순위 (별 갯수가 많을수록 빠름·간단):
#   ★★★  2~5분  · API key 한 줄 (firecrawl, buffer, youtube, discord)
#   ★★   10분 · Token + 권한 부여 (meta-ads, google-sheets, ga4)
#   ★    15분 + 1~2일 대기 · 승인 필요 (google-ads developer token)

# ════════════════════════════════════════════════
# Part 2 Ch1 — 데이터 분석 3개 MCP
# ════════════════════════════════════════════════

# [1-2] Google Sheets · OAuth 기반 (별도 .env 키 없음)
# 자격증명: mcp-server/oauth_credentials.json (Google Cloud Console > Desktop App)
# 발급: https://console.cloud.google.com/apis/credentials  · 약 10분  · ★★
# 토큰: mcp-server/token.json (Claude 재시작 시 자동 생성)

# [1-3] GA4 · ★★ 12~15분
# 발급 URL: https://console.cloud.google.com/iam-admin/serviceaccounts (Service Account + JSON 키)
#          + analytics.google.com 에서 client_email 에 뷰어 권한 부여
GA4_SERVICE_ACCOUNT_JSON=                      # 절대경로 예: /Users/me/.config/gcp/ga4-service-account.json
GA4_PROPERTY_ID=                               # GA4 속성 ID (숫자 9자리, properties/ 접두사 X)

# [1-4] Firecrawl · ★★★ 2분
# 발급 URL: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=                             # fc-xxx 형식

# ════════════════════════════════════════════════
# Part 2 Ch2 — 콘텐츠·영상·디자인 4개 MCP
# ════════════════════════════════════════════════

# [2-1] Figma · Claude.ai OAuth 자동 (별도 .env 키 없음)
# Claude.ai > Settings > Integrations > Figma > Connect 한 번만

# [2-2] YouTube Data API v3 · ★★★ 5분
# 발급 URL: https://console.cloud.google.com/apis/credentials
#          (API Library 에서 "YouTube Data API v3" 활성화 후 API key)
YOUTUBE_API_KEY=                               # AIza... 형식

# [2-3] Higgsfield · Claude.ai OAuth 자동 (별도 .env 키 없음)

# [2-7] 영상제작 트리오
# Hyperframes · 로컬 npm (별도 키 불필요, marketing-os/hyperframes/ 에서 npm install)
# HeyGen · ★★★ 3분
# 발급 URL: https://app.heygen.com/settings?nav=Subscriptions > API
HEYGEN_API_KEY=                                # 토큰 문자열

# ElevenLabs · ★★★ 3분
# 발급 URL: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=                            # sk_xxx 형식

# ════════════════════════════════════════════════
# Part 2 Ch3 — 배포와 광고 2개 MCP
# ════════════════════════════════════════════════

# [3-1] Buffer · ★★★ 5분
# 발급 URL: https://publish.buffer.com/account/apps > Access Tokens
# 사전 작업: Buffer 에 LinkedIn/Twitter/Instagram/Facebook 4개 채널 연결 권장
BUFFER_ACCESS_TOKEN=                           # 1/xxx 형식

# [3-2-a] Meta Ads · ★★★ 1분 (Claude.ai OAuth 자동 — 별도 .env 키 없음)
# 등록: claude mcp add --transport http --scope user meta-ads https://mcp.facebook.com/ads
# 인증: Claude Code 안에서 첫 사용 시 OAuth 자동 (5 scope: ads_management, ads_read,
#       catalog_management, business_management, pages_show_list)
# System User Token / META_ACCESS_TOKEN / META_AD_ACCOUNT_ID 모두 불필요

# [3-2-b] Google Ads · ★ 15분 + 1~2일 승인 대기
# 발급 URL: https://ads.google.com/aw/apicenter (Developer Token 신청)
#          + OAuth Refresh Token (npx mcp-google-ads-auth 명령)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=                          # ...apps.googleusercontent.com 형식
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=                        # 하이픈 없는 10자리 (Customer ID)

# (선택) Naver 검색광고 · Part 6
NAVER_API_KEY=
NAVER_SECRET_KEY=
NAVER_CUSTOMER_ID=

# ════════════════════════════════════════════════
# Part 2 Ch4 — 협업과 관리 2개 MCP
# ════════════════════════════════════════════════

# [4-1] Notion · Claude.ai OAuth 자동 (별도 .env 키 없음)
# Claude.ai > Settings > Integrations > Notion > Connect 한 번만

# [4-2] Discord · ★★ 10분
# 발급 URL: https://discord.com/developers/applications (New Application > Bot > Token)
# 사전 작업: Bot 권한 (Send Messages + Embed Links + Read Messages) + 본인 서버에 OAuth URL 로 초대
DISCORD_BOT_TOKEN=                             # MT... 형식
DISCORD_APPLICATION_ID=                        # Bot 생성 후 General Information > Application ID
DISCORD_GUILD_ID=                              # 테스트 서버 ID (개발자 모드 > 서버 우클릭 > ID 복사)
DISCORD_WEBHOOK_URL=                           # (선택) 일반 발송용 메인 webhook
DISCORD_WEBHOOK_ALERTS=                        # 실패·임계치 위반 → #marketing-alerts 채널 webhook
DISCORD_WEBHOOK_APPROVALS=                     # 위험 도구 승인 요청 → #approvals 채널 webhook
DISCORD_CHANNEL_ID_MARKETING_OS=               # 메인 봇 채널 ID (Discord 채널 우클릭 > ID 복사)
DISCORD_CHANNEL_ID_ALERTS=                     # (선택) 광고 임계치 알림 채널
DISCORD_CHANNEL_ID_APPROVALS=                  # (선택) 콘텐츠·예산 승인 채널

# ════════════════════════════════════════════════
# Claude.ai 통합 (별도 .env 키 없음, OAuth 자동)
# ════════════════════════════════════════════════
# Gmail · Google Calendar · Google Drive · Slack · Canva · Adobe
# Claude.ai > Settings > Integrations 에서 각각 Connect 한 번만

# ════════════════════════════════════════════════
# 운영 설정
# ════════════════════════════════════════════════

TIMEZONE=Asia/Seoul
DEFAULT_LOCALE=ko-KR
OUTPUTS_DIR=./outputs                          # 산출물 저장 경로 (상대/절대)

# (선택) Coupler.io · 다중 데이터 소스 통합
COUPLER_API_KEY=

# ════════════════════════════════════════════════
# 발급 진행률 자동 추적 (Claude 가 자동 갱신)
# ════════════════════════════════════════════════
# 아래 라인은 /mcp설치-전체 스킬이 자동 업데이트.
# 사용자가 직접 편집할 필요 없음.
#
# _MCP_PROGRESS=0/8
# _LAST_UPDATED=
