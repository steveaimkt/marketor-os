{
  "name": "marketing-os",
  "version": "1.0.0",
  "description": "30개 마케팅 에이전트를 Claude Agent SDK로 전체 관리하는 오케스트레이터",
  "type": "module",
  "scripts": {
    "agent": "node scripts/agent-runner.mjs",
    "dashboard": "node tools/dashboard/server.mjs",
    "status": "node scripts/status-scan.mjs --open",
    "agents:list": "node scripts/agent-runner.mjs --list",
    "bot": "node discord-bot/server.mjs",
    "bot:register": "node discord-bot/register-commands.mjs",
    "bot:register:global": "node discord-bot/register-commands.mjs --global",
    "cron:setup": "bash automation/setup-launchd.sh install",
    "cron:status": "bash automation/setup-launchd.sh status",
    "cron:uninstall": "bash automation/setup-launchd.sh uninstall",
    "healthcheck": "bash scripts/healthcheck-all.sh",
    "smoke": "bash automation/run-cron.sh 'smoke-test' 'say only the word: pong'",
    "validate": "bash scripts/validate-agents.sh && bash scripts/check-links.sh",
    "drift": "bash scripts/check-org-drift.sh"
  },
  "keywords": [
    "claude",
    "agent-sdk",
    "marketing",
    "automation"
  ],
  "author": "WMBB (Steve / 한성국)",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "discord.js": "^14.26.4"
  }
}
